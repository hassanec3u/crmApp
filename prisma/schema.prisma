// =====================================================================
//  Schéma Prisma — CRM Immobilier
// =====================================================================
//  Base de données : PostgreSQL (Supabase)
//
//  Deux URLs sont utilisées :
//   - DATABASE_URL  : pooler PgBouncer (mode transaction) pour Vercel
//   - DIRECT_URL    : connexion directe pour `prisma migrate`
//
//  Convention : noms de modèles et de champs en anglais pour rester
//  cohérent côté code TypeScript. Les libellés métier (statuts, tags…)
//  sont stockés en français dans la colonne `label`.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------
//  Énumérations
// ---------------------------------------------------------------------

/// Rôles disponibles pour un utilisateur de l'application.
enum Role {
  ADMIN
  MANAGER
  AGENT
}

/// Type de tâche / rappel commercial.
enum TaskType {
  RAPPEL
  RELANCE
  RDV
  VERIFICATION
  SUIVI
}

/// Type d'action enregistrée dans l'historique d'un prospect.
enum HistoriqueType {
  CALL
  EMAIL
  SMS
  MEETING
  NOTE
  STATUS_CHANGE
  TASK_CREATED
  TASK_DONE
  TAG_ADDED
  TAG_REMOVED
  OTHER
}

// ---------------------------------------------------------------------
//  Authentification — modèles requis par NextAuth + Prisma Adapter
//  Référence : https://authjs.dev/reference/adapter/prisma
// ---------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------
//  Modèles métier
// ---------------------------------------------------------------------

/// Utilisateur de l'application (agent immobilier, manager, admin).
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(AGENT)
  /// Hash bcrypt — connexion par email + mot de passe.
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth (NextAuth)
  accounts Account[]
  sessions Session[]

  // Métier
  prospects     Prospect[]
  statuts       Statut[]
  tags          Tag[]
  tasksAssigned Task[]             @relation("TaskAssignedUser")
  historiques   HistoriqueAction[]

  @@index([role])
}

/// Statut d'un prospect dans le pipeline commercial.
/// Peut être global (userId = null, créé par l'admin) ou personnel.
model Statut {
  id        String   @id @default(cuid())
  label     String
  /// Couleur d'affichage du statut (format `#RRGGBB`).
  couleur   String   @default("#3b82f6")
  /// Ordre d'affichage dans le kanban / pipeline.
  ordre     Int      @default(0)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  prospects Prospect[]

  @@unique([userId, label])
  @@index([userId, ordre])
}

/// Tag libre attachable à un prospect (ex. "Primo-accédant", "Investisseur"…).
model Tag {
  id        String   @id @default(cuid())
  label     String
  couleur   String   @default("#10b981")
  userId    String
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  prospects Prospect[] @relation("ProspectTags")

  @@unique([userId, label])
  @@index([userId])
}

/// Prospect immobilier : cœur métier du CRM.
model Prospect {
  id        String  @id @default(cuid())
  nom       String
  prenom    String?
  telephone String?
  email     String?
  /// Origine du prospect (LeBonCoin, SeLoger, Recommandation…).
  source    String?

  /// Statut courant (relation many-to-one vers Statut).
  statutId String?
  statut   Statut? @relation(fields: [statutId], references: [id], onDelete: SetNull)

  /// Tags multiples (many-to-many).
  tags Tag[] @relation("ProspectTags")

  /// Critères immobiliers stockés en JSON (souples).
  /// Exemple :
  /// {
  ///   "type": "appartement",
  ///   "transaction": "achat",
  ///   "budgetMin": 200000,
  ///   "budgetMax": 350000,
  ///   "surfaceMin": 50,
  ///   "pieces": 3,
  ///   "villes": ["Lyon", "Villeurbanne"],
  ///   "exterieur": true
  /// }
  criteres Json?

  /// Notes libres de l'agent (markdown autorisé côté UI).
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Agent propriétaire du prospect.
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks       Task[]
  historiques HistoriqueAction[]

  @@index([userId])
  @@index([statutId])
  @@index([createdAt])
}

/// Tâche / rappel rattaché à un prospect (rappeler, visite, relance…).
model Task {
  id          String   @id @default(cuid())
  type        TaskType @default(RAPPEL)
  titre       String
  commentaire String?  @db.Text
  /// Date (jour) à laquelle la tâche doit être réalisée.
  date        DateTime
  /// Heure stockée en chaîne `HH:mm` pour rester souple.
  heure       String?
  fait        Boolean  @default(false)

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  assignedUserId String
  assignedUser   User   @relation("TaskAssignedUser", fields: [assignedUserId], references: [id], onDelete: Cascade)

  googleCalendarEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedUserId, fait, date])
  @@index([assignedUserId, type, date])
  @@index([prospectId])
}

/// Trace de toute action significative effectuée sur un prospect.
/// Utilisée pour la timeline d'activité.
model HistoriqueAction {
  id      String         @id @default(cuid())
  type    HistoriqueType
  contenu String?        @db.Text

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([prospectId, createdAt])
  @@index([userId, createdAt])
}
